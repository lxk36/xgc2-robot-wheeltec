<?xml version="1.0"?>
<launch>
  <arg name="config_file" default="$(find wheeltec_swarm_ros_bridge)/config/ros_topics.yaml" />

  <node pkg="swarm_ros_bridge"
        type="bridge_node"
        name="swarm_bridge_node"
        output="screen">
    <rosparam command="load" file="$(arg config_file)" />
  </node>
</launch>
