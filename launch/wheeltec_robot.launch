<?xml version="1.0"?>
<launch>
  <arg name="usart_port_name" default="/dev/wheeltec_controller" />
  <arg name="serial_baud_rate" default="115200" />
  <arg name="odom_frame_id" default="odom_combined" />
  <arg name="robot_frame_id" default="base_footprint" />
  <arg name="gyro_frame_id" default="gyro_link" />

  <node pkg="turn_on_wheeltec_robot"
        type="wheeltec_robot_node"
        name="wheeltec_robot"
        output="screen">
    <param name="usart_port_name" value="$(arg usart_port_name)" />
    <param name="serial_baud_rate" value="$(arg serial_baud_rate)" />
    <param name="odom_frame_id" value="$(arg odom_frame_id)" />
    <param name="robot_frame_id" value="$(arg robot_frame_id)" />
    <param name="gyro_frame_id" value="$(arg gyro_frame_id)" />
  </node>
</launch>
